# Used for production/release builds and EAS. Matches nginx: SPA + `/api` on same host.
# Verbose [API] request logs in a **release** APK: uncomment next line and rebuild (ignored in __DEV__).
EXPO_PUBLIC_API_DEBUG=1
EXPO_PUBLIC_API_ORIGIN=http://5.189.173.244:8090
EXPO_PUBLIC_WEB_ORIGIN=http://5.189.173.244:8090
# Optional: iOS native map still uses react-native-maps (Apple/Google); without a key the home tab falls back to list UI.
# Android home map uses MapLibre + OpenStreetMap and does not need this key.
# EXPO_PUBLIC_GOOGLE_MAPS_ANDROID_API_KEY=
