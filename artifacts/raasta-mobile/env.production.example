# Copy to .env and load before release builds, or set the same vars in EAS (Secrets) / CI.
# Required: one of the two API options below.
#
# Full API origin (recommended for split api.example.com + app.example.com):
# EXPO_PUBLIC_API_ORIGIN=https://api.example.com
#
# Or hostname-only (HTTPS implied):
# EXPO_PUBLIC_DOMAIN=api.example.com
#
# Public URL of the **Vite web** app — used by expo-router; must match where users open the site:
EXPO_PUBLIC_WEB_ORIGIN=https://app.example.com
