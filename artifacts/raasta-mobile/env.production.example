# Copy to .env (gitignored) or set in EAS Secrets for release builds.
#
# Full API origin (no trailing slash), same host as SPA in our nginx setup:
# EXPO_PUBLIC_API_ORIGIN=http://5.189.173.244:8090
#
# Public **web** URL (expo-router). Same origin as API in single-host deploy:
# EXPO_PUBLIC_WEB_ORIGIN=http://5.189.173.244:8090
#
# Optional: hostname-only API (HTTPS implied) instead of EXPO_PUBLIC_API_ORIGIN:
# EXPO_PUBLIC_DOMAIN=api.example.com
