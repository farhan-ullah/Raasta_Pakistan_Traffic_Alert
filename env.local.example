# Copy to `.env.local` and adjust for your machine, then:
#   set -a && source .env.local && set +a && pnpm run db:push
# Or export DATABASE_URL before starting the API.
#
# Example (Homebrew Postgres, OS username matches DB role — no password):
# DATABASE_URL=postgresql://YOUR_MAC_USERNAME@localhost:5432/postgres
#
# Example (dedicated DB and password):
# DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/raasta

DATABASE_URL=postgresql://YOUR_USER@localhost:5432/postgres
